<?xml version="1.0" encoding="utf-8"?>
<!--
    DETOX APP BLOCKER - AndroidManifest.xml
    ======================================

    IMPORTANT SETUP INSTRUCTIONS:
    1. Build and install the app
    2. Grant required permissions:
       - Go to Settings > Apps > Detox > Permissions
       - Enable "Display over other apps" (SYSTEM_ALERT_WINDOW)
    3. Enable Accessibility Service:
       - Go to Settings > Accessibility > Detox App Blocker
       - Turn ON the service
       - This is required to detect foreground apps
    4. Disable battery optimization:
       - Settings > Apps > Detox > Battery > Unrestricted
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        PERMISSIONS EXPLANATION:
        - FOREGROUND_SERVICE: Required to run the persistent service
        - SYSTEM_ALERT_WINDOW: Required to show block overlay
        - PACKAGE_USAGE_STATS: Optional - to get app usage info
        - RECEIVE_BOOT_COMPLETED: Optional - auto-start on boot
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <uses-permission android:name="android.permission.REORDER_TASKS" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".DetoxApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Detox"
        tools:targetApi="31">

        <!--
            MainActivity: Entry point of the app
            Shows list of apps and blocked status
        -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            BlockOverlayActivity: Shows "App Blocked" screen
            NoHistory=true so it doesn't stay in back stack
            ExcludeFromRecents=true so it's hidden from app switcher
            TaskOnHome=false keeps it on top of blocked app
        -->
        <activity
            android:name=".ui.BlockOverlayActivity"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@style/Theme.Detox.BlockOverlay"
            android:launchMode="singleInstance"
            android:clearTaskOnLaunch="true"
            android:stateNotNeeded="true"
            android:exported="false" />

        <!--
            AppBlockAccessibilityService: Detects foreground app changes
            This is the core detection mechanism
        -->
        <service
            android:name=".service.AppBlockAccessibilityService"
            android:exported="true"
            android:label="@string/app_blocker_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!--
            AppBlockService: Foreground service to keep app alive
            Runs persistently in background
        -->
        <service
            android:name=".service.AppBlockService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>