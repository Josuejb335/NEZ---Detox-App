<resources>
    <!-- Base application theme -->
    <style name="Theme.Detox" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>
    </style>

    <!-- Theme for the block overlay - use a dialog theme that covers the whole screen -->
    <style name="Theme.Detox.BlockOverlay" parent="android:Theme.Material.Dialog.NoActionBar">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>