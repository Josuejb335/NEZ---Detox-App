<?xml version="1.0" encoding="utf-8"?>
<!--
    DETOX - Digital Wellbeing App Blocker
    ======================================

    This app helps users reduce screen time by temporarily blocking
    distracting apps. Uses Accessibility Service for foreground app
    detection (required for functionality).

    COMPLIANCE NOTES:
    - Accessibility Service is ONLY used for digital wellbeing
    - User has full control and can disable at any time
    - No data collection or transmission
    - App does NOT prevent uninstall
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Foreground service - required for background monitoring -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Accessibility Service - for detecting foreground apps
         This is a core feature for digital wellbeing 
         Note: This permission is required to declare an accessibility service.
               The lint warning is a false positive; we don't use it directly. -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- Query apps - to show list of installed apps -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".DetoxApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Detox"
        tools:targetApi="34">

        <!-- Main Activity - App entry point -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false" />

        <!-- Block Activity - Shown when app is blocked
             Transparent blocking UI, noHistory to prevent back stack -->
        <activity
            android:name=".blocking.BlockActivity"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:launchMode="singleTask"
            android:exported="false"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

        <!-- Accessibility Service - Detects foreground app changes
             REQUIRED: User must enable in Settings > Accessibility

             Disclosure: This service is used solely for digital wellbeing
             purposes. It detects when the user opens apps and checks if
             they are in the user's block list. No personal data is collected
             or transmitted. -->
        <service
            android:name=".service.MonitorAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:description="@string/accessibility_service_description"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Foreground Service - Keeps app alive during blocking
             Required by Android for background operation -->
        <service
            android:name=".service.MonitorForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
